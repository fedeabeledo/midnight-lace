<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MidnightLace" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/rojo_oscuro</item>
        <item name="colorPrimaryDark">@color/burdeos</item>
        <item name="colorAccent">@color/rosa_decorativo</item>
        <item name="android:windowBackground">@color/crema</item>
        <item name="android:statusBarColor">@color/rojo_oscuro</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <style name="Theme.MidnightLace.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
